{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/discovery",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/send",
      "schedule": "19 * * * *"
    },
    {
      "path": "/api/cron/agency-discovery",
      "schedule": "30 */3 * * *"
    },
    {
      "path": "/api/cron/standup-discovery",
      "schedule": "15 */3 * * *"
    },
    {
      "path": "/api/cron/media-org-discovery",
      "schedule": "45 */3 * * *"
    }
  ],
  "functions": {
    "app/api/cron/discovery/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/send/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/agency-discovery/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/standup-discovery/route.ts": {
      "maxDuration": 800
    },
    "app/api/cron/media-org-discovery/route.ts": {
      "maxDuration": 800
    }
  }
}
