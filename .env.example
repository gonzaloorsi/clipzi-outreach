# Postgres (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# YouTube API keys (rotate up to 10 — code reads YOUTUBE_API_KEY (legacy) + _1..10)
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=
YOUTUBE_API_KEY_4=
YOUTUBE_API_KEY_5=

# Email sending (Pilar 2 lite — single sender via Resend)
RESEND_API_KEY=
SENDER_EMAIL=g@clipzi.dev
SENDER_NAME=Gonzalo Orsi
DAILY_SEND_CAP=100

# Cron auth (Vercel injects this header automatically)
CRON_SECRET=

# LLM personalization (Pilar 3 — coming later)
ANTHROPIC_API_KEY=
