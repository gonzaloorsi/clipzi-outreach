# Postgres (Neon)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# YouTube API keys (rotate up to 10 — code reads YOUTUBE_API_KEY (legacy) + _1..10)
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
YOUTUBE_API_KEY_3=
YOUTUBE_API_KEY_4=
YOUTUBE_API_KEY_5=

# Email sending (Pilar 2 lite — multi-sender pool via Resend)
RESEND_API_KEY=
SENDER_EMAIL_1=g@clipzi.dev
SENDER_EMAIL_2=
SENDER_EMAIL_3=
# ...up to SENDER_EMAIL_10. Each inbox must be verified in Resend.
SENDER_NAME=Gonzalo Orsi
# Daily send limit PER INBOX. Total daily capacity = N_senders * DAILY_SEND_CAP.
DAILY_SEND_CAP=100

# Cron auth (Vercel injects this header automatically)
CRON_SECRET=

# Outreach report email (sent after every cron run that produced sends).
# REPORT_EMAIL defaults to gonzaloorsi@gmail.com if unset.
# REPORT_FROM_EMAIL must be on a Resend-verified domain — falls back to
# SENDER_EMAIL_1 if unset.
REPORT_EMAIL=
REPORT_FROM_EMAIL=

# LLM personalization (Pilar 3 — coming later)
ANTHROPIC_API_KEY=
